# 本地视频目录（JSON数组，每个目录对应一个源）
VIDEO_DIRS=["/videos/主播舞","/videos/抖音","/videos/肉体"]
SOURCE_NAMES=["主播舞","抖音","肉体"]

# 远程API视频源（JSON数组，每项name+url）
# url指向的API需返回JSON: {"video_url":"https://直链.mp4","name":"标题"}
# 兼容格式: {"url":"...","title":"..."} 或 {"data":{"url":"...","title":"..."}}
REMOTE_SOURCES=[]

# API签名密钥（部署时务必修改为随机字符串）
API_SECRET=change...ring
# 服务端口
PORT=8080